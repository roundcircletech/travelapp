# --- Ports (Docker Compose) ---
# Frontend is fixed on port 80 in docker-compose.yml
BACKEND_PORT=8080

# Docker internal hostname for nginx → backend proxy (default: backend service name)
# BACKEND_HOST=backend

# Comma-separated browser origins for direct backend API access (optional).
# Unset when nginx proxies /api on the same host (recommended for production).
# Examples:
#   CORS_ALLOWED_ORIGINS=http://203.0.113.50,http://mydomain.com
#   CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_ORIGINS=

# --- Backend (AI & mail) ---
AI_API_KEY=
# AI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent
MAIL_USERNAME=
MAIL_PASSWORD=
